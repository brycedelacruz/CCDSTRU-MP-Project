#include <stdio.h>

/* =========================================================
   CONSTANTS
   C = {1,2,3}, M = C x C (3x3 grid), N = {0..16}
   ========================================================= */

#define GRID      3    /* size of one side: C = {1,2,3}   */
#define MAX_CELLS 9    /* |M| = 3 * 3                     */
#define VAL_LIMIT 20   /* over when val >= 20             */
#define FREE_LIMIT 3   /* over when |F| == 3              */

/* =========================================================
   TYPES
   ========================================================= */

typedef int bool;
#define TRUE  1
#define FALSE 0

/* A position in M = C x C */
typedef struct {
    int row;   /* 1..3 */
    int col;   /* 1..3 */
} Pos;

/* A subset of M stored as an array of Pos */
typedef struct {
    Pos  cells[MAX_CELLS];
    int  size;
} PosSet;

/* Full game state matching all system variables */
typedef struct {
    int    good;
    int    go;      /* TRUE = Red's turn, FALSE = Blue's turn */
    int    start;
    int    over;
    int    found;
    int    val;
    PosSet R;       /* Red pieces                */
    PosSet B;       /* Blue pieces               */
    PosSet S;       /* ever-selected positions   */
    PosSet T;       /* exploded positions        */
} GameState;

/* =========================================================
   FORWARD DECLARATIONS
   ========================================================= */

/* Set operations */
int    posEqual(Pos a, Pos b);
int    inSet(PosSet *set, Pos p);
void   addToSet(PosSet *set, Pos p);
void   removeFromSet(PosSet *set, Pos p);
int    freeCount(GameState *gs);
int    validPos(Pos p);

/* Display */
void   clearScreen(void);
void   printBoard(GameState *gs);
void   printState(GameState *gs);
void   printResult(GameState *gs);
int    promptPos(const char *prompt, Pos *out);

/* Game logic */
void   initGame(GameState *gs);
int    checkOver(GameState *gs);
void   Remove(GameState *gs, Pos pos);
void   Replace(GameState *gs, Pos pos);
void   Expand(GameState *gs, Pos pos);
void   Update(GameState *gs, Pos pos);
void   NextPlayerMove(GameState *gs, Pos pos);
void   GameOver(GameState *gs);

/* =========================================================
   SET OPERATIONS
   ========================================================= */

/* Returns TRUE if positions a and b are the same cell */
int posEqual(Pos a, Pos b)
{
    return (a.row == b.row && a.col == b.col);
}

/* Returns TRUE if p is a member of set.
   FIX: removed early return inside loop; uses a flag instead. */
int inSet(PosSet *set, Pos p)
{
    int i;
    int found = FALSE;

    for (i = 0; i < set->size; i++) {
        if (posEqual(set->cells[i], p))
            found = TRUE;
    }
    return found;
}

/* Adds p to set only if not already present and set is not full */
void addToSet(PosSet *set, Pos p)
{
    if (!inSet(set, p) && set->size < MAX_CELLS) {
        set->cells[set->size] = p;
        set->size++;
    }
}

/* Removes p from set by shifting remaining elements left.
   FIX: removed early return inside void function;
        uses a flag and only shifts when the element was found. */
void removeFromSet(PosSet *set, Pos p)
{
    int i, j;
    int found = FALSE;
    int idx   = -1;

    for (i = 0; i < set->size; i++) {
        if (posEqual(set->cells[i], p) && !found) {
            found = TRUE;
            idx   = i;
        }
    }

    if (found) {
        for (j = idx; j < set->size - 1; j++)
            set->cells[j] = set->cells[j + 1];
        set->size--;
    }
}

/* |F| = |M| - |R U B|: counts cells in M not in R and not in B */
int freeCount(GameState *gs)
{
    int r, c, count;
    Pos p;

    count = 0;
    for (r = 1; r <= GRID; r++) {
        for (c = 1; c <= GRID; c++) {
            p.row = r;
            p.col = c;
            if (!inSet(&gs->R, p) && !inSet(&gs->B, p))
                count++;
        }
    }
    return count;
}

/* Returns TRUE if pos is inside M = C x C */
int validPos(Pos p)
{
    return (p.row >= 1 && p.row <= GRID &&
            p.col >= 1 && p.col <= GRID);
}

/* =========================================================
   DISPLAY
   ========================================================= */

/* Clears the terminal screen using ANSI escape codes */
void clearScreen(void)
{
    printf("\033[2J\033[H");
}

/* Renders the 3x3 board:  R = Red, B = Blue, . = free */
void printBoard(GameState *gs)
{
    int r, c;
    Pos p;

    printf("\n     Col1  Col2  Col3\n");
    printf("    +-----+-----+-----+\n");
    for (r = 1; r <= GRID; r++) {
        printf("Row%d|", r);
        for (c = 1; c <= GRID; c++) {
            p.row = r;
            p.col = c;
            if      (inSet(&gs->R, p)) printf("  R  |");
            else if (inSet(&gs->B, p)) printf("  B  |");
            else                       printf("  .  |");
        }
        printf("\n    +-----+-----+-----+\n");
    }
    printf("\n");
}

/* Prints all system variable values */
void printState(GameState *gs)
{
    int i;

    printf("--- State: val=%d  |R|=%d  |B|=%d  |F|=%d  "
           "go=%s  start=%s  over=%s ---\n",
           gs->val,
           gs->R.size, gs->B.size, freeCount(gs),
           gs->go    ? "Red"  : "Blue",
           gs->start ? "yes"  : "no",
           gs->over  ? "yes"  : "no");

    printf("  S={ ");
    for (i = 0; i < gs->S.size; i++)
        printf("(%d,%d) ", gs->S.cells[i].row, gs->S.cells[i].col);
    printf("}  T={ ");
    for (i = 0; i < gs->T.size; i++)
        printf("(%d,%d) ", gs->T.cells[i].row, gs->T.cells[i].col);
    printf("}\n\n");
}

/* Prints the final game result */
void printResult(GameState *gs)
{
    printf("========================================\n");
    printf("              GAME OVER\n");
    printf("========================================\n");
    printf("  Red pieces  : %d\n", gs->R.size);
    printf("  Blue pieces : %d\n", gs->B.size);
    printf("  Moves made  : %d\n", gs->val);
    printf("  Result      : ");

    if      (gs->R.size > gs->B.size) printf("RED WINS!\n");
    else if (gs->R.size < gs->B.size) printf("BLUE WINS!\n");
    else                               printf("DRAW\n");

    printf("========================================\n\n");
}

/* Reads a row and column from stdin.
   Returns TRUE on valid input, FALSE otherwise.
    */
int promptPos(const char *prompt, Pos *out)
{
    int r, c, ch;
    int result = FALSE;

    printf("%s (row col, e.g. 1 2): ", prompt);

    if (scanf("%d %d", &r, &c) != 2) {
        /* flush bad input */
        ch = getchar();
        while (ch != '\n' && ch != EOF)
            ch = getchar();
    } else if (r < 1 || r > GRID || c < 1 || c > GRID) {
        printf("  [!] Row and col must each be 1, 2, or 3.\n");
    } else {
        out->row = r;
        out->col = c;
        result   = TRUE;
    }

    return result;
}

/* =========================================================
   SYSTEM INITIALIZATION
   good=false  go=true  start=true  found=false  val=0
   R={}  B={}  S={}  T={}
   ========================================================= */

void initGame(GameState *gs)
{
    gs->good  = FALSE;
    gs->go    = TRUE;
    gs->start = TRUE;
    gs->over  = FALSE;
    gs->found = FALSE;
    gs->val   = 0;
    gs->R.size = 0;
    gs->B.size = 0;
    gs->S.size = 0;
    gs->T.size = 0;
}

/* =========================================================
   SYSTEM FACTS
   over <-> (|F|=3  v  val>=20  v
            (not start ^ (|R|>0 ^ |B|=0  v  |R|=0 ^ |B|>0)))
   FIX: removed early return statements; uses a single return at end.
   ========================================================= */

int checkOver(GameState *gs)
{
    int f = freeCount(gs);
    int r = gs->R.size;
    int b = gs->B.size;
    int result;

    if (f == FREE_LIMIT)
        result = TRUE;
    else if (gs->val >= VAL_LIMIT)
        result = TRUE;
    else if (!gs->start && ((r > 0 && b == 0) || (r == 0 && b > 0)))
        result = TRUE;
    else
        result = FALSE;

    return result;
}

/* =========================================================
   Remove(pos in M)
     go  -> R = R - {pos}
     ~go -> B = B - {pos}
     S   = S - {pos}
     T   = T - {pos}
   ========================================================= */

void Remove(GameState *gs, Pos pos)
{
    if (gs->go)
        removeFromSet(&gs->R, pos);
    else
        removeFromSet(&gs->B, pos);

    removeFromSet(&gs->S, pos);
    removeFromSet(&gs->T, pos);
}

/* =========================================================
   Replace(pos in M)
     found = false
     (go  ^ pos in B) -> B = B-{pos} ^ found = true
     (go  ^ pos in R) -> found = true
     (go  ^ pos not in R) -> R = R U {pos}
     (~go ^ pos in R) -> R = R-{pos} ^ found = true
     (~go ^ pos in B) -> found = true
     (~go ^ pos not in B) -> B = B U {pos}
     (found ^ pos not in S) -> S = S U {pos} ^ found = false
     (found ^ pos in S ^ pos not in T) -> T = T U {pos} ^ Expand(pos)

   ========================================================= */

void Replace(GameState *gs, Pos pos)
{
    if (validPos(pos)) {
        gs->found = FALSE;

        if (gs->go) {
            if (inSet(&gs->B, pos)) {
                removeFromSet(&gs->B, pos);
                gs->found = TRUE;
            } else if (inSet(&gs->R, pos)) {
                gs->found = TRUE;
            } else {
                addToSet(&gs->R, pos);
            }
        } else {
            if (inSet(&gs->R, pos)) {
                removeFromSet(&gs->R, pos);
                gs->found = TRUE;
            } else if (inSet(&gs->B, pos)) {
                gs->found = TRUE;
            } else {
                addToSet(&gs->B, pos);
            }
        }

        if (gs->found && !inSet(&gs->S, pos)) {
            addToSet(&gs->S, pos);
            gs->found = FALSE;
        }
        if (gs->found && inSet(&gs->S, pos) && !inSet(&gs->T, pos)) {
            addToSet(&gs->T, pos);
            Expand(gs, pos);
        }
    }
}

/* =========================================================
   Expand(pos in M)
     (a,b) = pos
     u=(a-1,b)  d=(a+1,b)  k=(a,b-1)  r=(a,b+1)
     Remove(pos)
     go  -> Replace(u)    [Red spreads UP]
     ~go -> Replace(d)    [Blue spreads DOWN]
     Replace(k)           [both spread LEFT]
     Replace(r)           [both spread RIGHT]
   ========================================================= */

void Expand(GameState *gs, Pos pos)
{
    Pos u, d, k, r;

    u.row = pos.row - 1;  u.col = pos.col;
    d.row = pos.row + 1;  d.col = pos.col;
    k.row = pos.row;      k.col = pos.col - 1;
    r.row = pos.row;      r.col = pos.col + 1;

    Remove(gs, pos);

    if (gs->go)
        Replace(gs, u);   /* Red   -> UP    */
    else
        Replace(gs, d);   /* Blue  -> DOWN  */

    Replace(gs, k);       /* both  -> LEFT  */
    Replace(gs, r);       /* both  -> RIGHT */
}

/* =========================================================
   Update(pos in M)
     good = false
     (pos not in S) -> S = S U {pos} ^ good = ~good
     (~good ^ pos in S ^ pos not in T) -> T = T U {pos} ^ Expand(pos)
   ========================================================= */

void Update(GameState *gs, Pos pos)
{
    gs->good = FALSE;

    if (!inSet(&gs->S, pos)) {
        addToSet(&gs->S, pos);
        gs->good = !gs->good;   /* good becomes TRUE */
    }

    if (!gs->good && inSet(&gs->S, pos) && !inSet(&gs->T, pos)) {
        addToSet(&gs->T, pos);
        Expand(gs, pos);
    }
}

/* =========================================================
   NextPlayerMove(pos in M)
     (~over ^ start ^  go) -> R=R U {pos} ^ S=S U {pos} ^ good=true
     (~over ^ start ^ ~go) -> B=B U {pos} ^ S=S U {pos} ^ good=true
     (~over ^ ~start ^ (go ^ pos in R  v  ~go ^ pos in B))
                            -> Update(pos) ^ good=true
     (start ^ |R|=1 ^ |B|=1) -> start=false
     (~over ^ good) -> good=~good ^ go=~go ^ val=val+1
   ========================================================= */

void NextPlayerMove(GameState *gs, Pos pos)
{
    gs->over = checkOver(gs);

    if (!gs->over && gs->start && gs->go) {
        addToSet(&gs->R, pos);
        addToSet(&gs->S, pos);
        gs->good = TRUE;
    } else if (!gs->over && gs->start && !gs->go) {
        addToSet(&gs->B, pos);
        addToSet(&gs->S, pos);
        gs->good = TRUE;
    } else if (!gs->over && !gs->start) {
        if ((gs->go  && inSet(&gs->R, pos)) ||
            (!gs->go && inSet(&gs->B, pos))) {
            Update(gs, pos);
            gs->good = TRUE;
        }
    }

    if (gs->start && gs->R.size == 1 && gs->B.size == 1)
        gs->start = FALSE;

    if (!gs->over && gs->good) {
        gs->good = !gs->good;
        gs->go   = !gs->go;
        gs->val++;
    }

    gs->over = checkOver(gs);
}

/* =========================================================
   GameOver()
     (over ^ |R| > |B|) -> result = "R wins"
     (over ^ |R| < |B|) -> result = "B wins"
     (over ^ |R| = |B|) -> result = "draw"
   ========================================================= */

void GameOver(GameState *gs)
{
    printResult(gs);
}

/* =========================================================
   MAIN - Game loop
   ========================================================= */

int main(void)
{
    GameState gs;
    Pos       pos;
    int       valid;
    int       wasInS, wasInT;

    initGame(&gs);

    /* --------------------------------------------------
       STEP 1: START PHASE
       Red places one piece, then Blue places one piece.
       Both may place anywhere on the empty board.
       -------------------------------------------------- */

    /* Red places */
    clearScreen();
    printf("==========================================\n");
    printf("   CCDSTRU  -  Term 2, AY 2025-2026\n");
    printf("   De La Salle University\n");
    printf("==========================================\n\n");
    printf("[START PHASE]\n");
    printf("Each player places ONE piece anywhere.\n\n");
    printf("--- RED's turn to place ---\n");
    printBoard(&gs);
    do {
        valid = promptPos("RED   place your piece", &pos);
        if (valid && (inSet(&gs.R, pos) || inSet(&gs.B, pos))) {
            printf("  [!] Cell already occupied. Choose another.\n");
            valid = FALSE;
        }
    } while (!valid);
    NextPlayerMove(&gs, pos);
    printf("  Red placed at (%d,%d).\n\n", pos.row, pos.col);

    /* Blue places */
    clearScreen();
    printf("==========================================\n");
    printf("   CCDSTRU  -  Term 2, AY 2025-2026\n");
    printf("   De La Salle University\n");
    printf("==========================================\n\n");
    printf("[START PHASE]\n");
    printf("Each player places ONE piece anywhere.\n\n");
    printf("--- BLUE's turn to place ---\n");
    printBoard(&gs);
    do {
        valid = promptPos("BLUE  place your piece", &pos);
        if (valid && (inSet(&gs.R, pos) || inSet(&gs.B, pos))) {
            printf("  [!] Cell already occupied. Choose another.\n");
            valid = FALSE;
        }
    } while (!valid);
    NextPlayerMove(&gs, pos);
    printf("  Blue placed at (%d,%d).\n\n", pos.row, pos.col);

    /* --------------------------------------------------
       STEP 2-5: MAIN GAME LOOP
       Players alternate turns (go toggles each move).
       Selecting a piece:
         1st pick (not in S) -> tracked, no explosion
         2nd pick (in S, not in T) -> EXPLODES, spreads
         Already in T -> no effect (already exploded)
       Expansion removes the piece and spreads to:
         Red:  UP, LEFT, RIGHT
         Blue: DOWN, LEFT, RIGHT
       -------------------------------------------------- */

    while (!gs.over) {
        clearScreen();
        printf("==========================================\n");
        printf("   CCDSTRU  -  Term 2, AY 2025-2026\n");
        printf("   De La Salle University\n");
        printf("==========================================\n\n");
        printf("[MAIN GAME]\n");
        printf("Pick one of YOUR pieces each turn.\n");
        printf("  1st pick -> safe, piece is tracked\n");
        printf("  2nd pick -> EXPLODES, spreads to neighbors\n\n");
        printBoard(&gs);
        printState(&gs);

        printf("Turn %d  -  %s's turn\n",
               gs.val + 1, gs.go ? "RED" : "BLUE");

        do {
            valid = promptPos(
                gs.go ? "RED   select your piece"
                      : "BLUE  select your piece",
                &pos);
            if (valid && gs.go && !inSet(&gs.R, pos)) {
                printf("  [!] That is not a Red piece.\n");
                valid = FALSE;
            } else if (valid && !gs.go && !inSet(&gs.B, pos)) {
                printf("  [!] That is not a Blue piece.\n");
                valid = FALSE;
            }
        } while (!valid);

        wasInS = inSet(&gs.S, pos);
        wasInT = inSet(&gs.T, pos);

        NextPlayerMove(&gs, pos);

        if (wasInT) {
            printf("  (%d,%d) already exploded before - no effect.\n\n",
                   pos.row, pos.col);
        } else if (wasInS) {
            printf("  (%d,%d) EXPLODED! Spread to neighbors.\n\n",
                   pos.row, pos.col);
        } else {
            printf("  (%d,%d) selected and tracked (safe pick).\n\n",
                   pos.row, pos.col);
        }
    }

    /* --------------------------------------------------
       STEP 6-7: GAME OVER
       -------------------------------------------------- */
    clearScreen();
    printBoard(&gs);
    GameOver(&gs);

    return 0;
}
